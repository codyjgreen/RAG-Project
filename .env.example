# Copy this file to .env and fill in values. NEVER commit your real .env.

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- Database (Postgres + pgvector) ---
# When running via docker compose, host is the service name (e.g. "db").
DATABASE_URL=postgresql://raguser:ragpass@db:5432/ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb

# --- Ollama (local models, no API key needed) ---
# When the backend runs in Docker and Ollama runs on the host machine, use:
#   http://host.docker.internal:11434  (Mac/Windows)
# When running the backend directly on your machine, use:
#   http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Retrieval tuning (adjust during evaluation) ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
