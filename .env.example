# Copy this file to .env and fill in values. NEVER commit your real .env.

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- Database (Postgres + pgvector) ---
# Local dev (default): Postgres running on your machine.
DATABASE_URL=postgresql://localhost:5432/ragdb
POSTGRES_DB=ragdb
# If you containerize later (optional), point the host at the compose service name, e.g.:
#   DATABASE_URL=postgresql://raguser:ragpass@db:5432/ragdb

# --- Ollama (local models, no API key needed) ---
# Ollama runs as a local service on your machine:
OLLAMA_BASE_URL=http://localhost:11434
# If you run the backend inside Docker later, reach host Ollama with:
#   http://host.docker.internal:11434  (Mac/Windows)
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Retrieval tuning (adjust during evaluation) ---
CHUNK_SIZE=500
